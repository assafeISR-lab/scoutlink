generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Agent Profile ───────────────────────────────────────────────────────────
// Extends Supabase auth user with app-specific data
model Agent {
  id        String   @id // matches Supabase auth user id
  email     String   @unique
  fullName  String
  isAdmin   Boolean  @default(false)
  unitSystem String  @default("metric") // "metric" or "imperial"
  language  String   @default("en")     // "en" or "he"
  exportFormat String @default("pdf")   // "pdf", "csv", "both"
  sourceVisibility Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  ownedDatabases    PlayerDatabase[]       @relation("DatabaseOwner")
  databaseAccess    DatabaseAccess[]
  websites          AgentWebsite[]
  activityLogs      ActivityLog[]
  playerNotes       PlayerNote[]
  calendarEvents    CalendarEvent[]
  addedPlayers      Player[]               @relation("AddedByAgent")
  reports           Report[]
  evaluations       PlayerEvaluation[]
  uploadedFiles     PlayerFile[]
}

// ─── Player Database ─────────────────────────────────────────────────────────
model PlayerDatabase {
  id           String   @id @default(cuid())
  name         String
  ownerId      String
  columnConfig Json?    // string[] of visible column keys; null = use global settings
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  owner     Agent            @relation("DatabaseOwner", fields: [ownerId], references: [id])
  access    DatabaseAccess[]
  players   Player[]

  @@index([ownerId])
}

// ─── Database Access (permissions) ───────────────────────────────────────────
model DatabaseAccess {
  id         String   @id @default(cuid())
  databaseId String
  agentId    String
  permission String   // "read" or "contributor"
  createdAt  DateTime @default(now())

  database   PlayerDatabase @relation(fields: [databaseId], references: [id], onDelete: Cascade)
  agent      Agent          @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([databaseId, agentId])
  @@index([agentId])
}

// ─── Player ───────────────────────────────────────────────────────────────────
model Player {
  id           String   @id @default(cuid())
  databaseId   String
  addedById    String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Standard parameters
  firstName    String
  lastName     String
  middleName   String?
  dateOfBirth  DateTime?
  heightCm     Float?
  salaryCurrency Float?
  clubName     String?
  position     String?
  agentName    String?
  nationality  String?
  playsNational Boolean @default(false)
  available    Boolean @default(true)
  marketValue  Float?

  // Relations
  database     PlayerDatabase  @relation(fields: [databaseId], references: [id], onDelete: Cascade)
  addedBy      Agent           @relation("AddedByAgent", fields: [addedById], references: [id])
  fieldSources FieldSource[]
  customFields CustomField[]
  notes        PlayerNote[]
  evaluations  PlayerEvaluation[]
  files        PlayerFile[]
  timeline     TimelineEvent[]
  conflicts    DataConflict[]

  @@index([databaseId])
  @@index([addedById])
}

// ─── Field Source ─────────────────────────────────────────────────────────────
// Tracks where each piece of data came from
model FieldSource {
  id         String   @id @default(cuid())
  playerId   String
  fieldName  String   // e.g. "heightCm", "salary"
  value      String   // stored as string, converted on read
  sourceName String   // website name or "import" or "manual"
  sourceUrl  String?
  scrapedAt  DateTime @default(now())
  isActive   Boolean  @default(true) // false = deleted/overridden

  player     Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([playerId])
}

// ─── Custom Field ─────────────────────────────────────────────────────────────
model CustomField {
  id        String   @id @default(cuid())
  playerId  String
  fieldName String
  value     String
  createdAt DateTime @default(now())

  player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([playerId])
}

// ─── Data Conflict ────────────────────────────────────────────────────────────
model DataConflict {
  id          String   @id @default(cuid())
  playerId    String
  fieldName   String
  value1      String
  source1     String
  value2      String
  source2     String
  resolvedBy  String?  // which source won (auto or manual)
  overridden  Boolean  @default(false)
  createdAt   DateTime @default(now())

  player      Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([playerId])
}

// ─── Player Note ──────────────────────────────────────────────────────────────
model PlayerNote {
  id        String   @id @default(cuid())
  playerId  String
  agentId   String
  content   String
  createdAt DateTime @default(now())

  player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([playerId])
}

// ─── Timeline Event ───────────────────────────────────────────────────────────
model TimelineEvent {
  id        String   @id @default(cuid())
  playerId  String
  type      String   // "note", "club_change", "salary_change", "conflict", "deletion", "import"
  title     String
  detail    String?
  createdAt DateTime @default(now())

  player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([playerId])
}

// ─── Agent Website ────────────────────────────────────────────────────────────
model AgentWebsite {
  id           String   @id @default(cuid())
  agentId      String
  url          String
  name         String
  requiresLogin Boolean @default(false)
  loginStatus  String  @default("pending")  // "pending", "free", "login_required"
  username     String?  // encrypted
  password     String?  // encrypted
  trustRank    Int      @default(0)
  isActive     Boolean  @default(true)
  useForSearch Boolean  @default(true)
  country      String?  // e.g. "England", "Spain"
  category     String?  // "association", "club", "stats", "news"
  createdAt    DateTime @default(now())

  agent        Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([agentId, url])
}

// ─── Report ───────────────────────────────────────────────────────────────────
model Report {
  id           String   @id @default(cuid())
  agentId      String
  name         String
  databaseId   String
  databaseName String
  playerCount  Int
  players      Json     // snapshot of player rows at creation time
  createdAt    DateTime @default(now())

  agent        Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([agentId])
  @@index([databaseId])
}

// ─── Player Evaluation ───────────────────────────────────────────────────────
model PlayerEvaluation {
  id        String   @id @default(cuid())
  playerId  String
  agentId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Match context — specific to the observation session
  matchDate    DateTime?
  venue        String?   // e.g. "Bloomfield Stadium"
  competition  String?   // e.g. "Israeli Cup Semi-final" (may differ from player's regular league)
  opponent     String?   // who the player's team played against
  matchResult  String?   // e.g. "2-1 W"

  // Scout ratings (1–5, all optional — scout fills what they can assess)
  ratingTechnical    Int?
  ratingTactical     Int?
  ratingPhysical     Int?
  ratingMentality    Int?
  ratingPotential    Int?
  commentTechnical   String?
  commentTactical    String?
  commentPhysical    String?
  commentMentality   String?
  commentPotential   String?

  // Scout judgment
  recommendation String?  // "sign" | "monitor" | "trial" | "reject"
  confidence     String?  // "low" | "medium" | "high"
  nextAction     String?  // "watch_again" | "contact_agent" | "invite_trial" | "review_later"

  // Risk flags
  riskRelativeAge       Boolean @default(false)
  riskWeakCompetition   Boolean @default(false)
  riskPhysicalAdvantage Boolean @default(false)
  riskAttitudeDiscipline Boolean @default(false)
  riskFamilySurroundings Boolean @default(false)
  riskInjuryHistory      Boolean @default(false)

  // Raw match-day observations (separate from the informal PlayerNote section)
  observationNotes String?

  // AI-generated report
  reportDraft    String?  // stored after generation so it is not regenerated on every view
  reportFinalized Boolean @default(false)

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
  agent  Agent  @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([playerId])
  @@index([agentId])
}

// ─── Activity Log ─────────────────────────────────────────────────────────────
model ActivityLog {
  id        String   @id @default(cuid())
  agentId   String
  action    String   // "search", "import", "add_player", "delete", etc.
  detail    String?
  createdAt DateTime @default(now())

  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([agentId])
}

// ─── Name Banks ──────────────────────────────────────────────────────────────
model AgentNameBank {
  id        String   @id @default(cuid())
  name      String   @unique
  phone     String?
  createdAt DateTime @default(now())
}

model ReferralNameBank {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
}

// ─── Player File ─────────────────────────────────────────────────────────────
model PlayerFile {
  id           String   @id @default(cuid())
  playerId     String
  uploadedById String
  fileName     String
  storagePath  String   // path within Supabase Storage bucket
  fileUrl      String   // public URL
  fileSize     Int      // bytes
  mimeType     String
  createdAt    DateTime @default(now())

  player       Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  uploadedBy   Agent    @relation(fields: [uploadedById], references: [id], onDelete: Cascade)

  @@index([playerId])
}

// ─── Calendar Event ───────────────────────────────────────────────────────────
model CalendarEvent {
  id          String   @id @default(cuid())
  agentId     String
  title       String
  type        String   // "meeting", "call", "deadline", "reminder"
  notes       String?
  startAt     DateTime
  linkedPlayerId String?
  createdAt   DateTime @default(now())

  agent       Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([agentId])
}
